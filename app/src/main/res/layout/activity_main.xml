<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Judul -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kamusy Kamus Offline"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="12dp" />

    <!-- Switch toggle Inggris <-> Indonesia -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_lang_indonesia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Indonesia"
            android:textSize="14sp"
            android:textColor="#757575" />

        <Switch
            android:id="@+id/switch_language"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:checked="true" />

        <TextView
            android:id="@+id/tv_lang_english"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="English"
            android:textSize="14sp"
            android:textColor="#757575" />

    </LinearLayout>

    <!-- Search bar -->
    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cari kata..."
        android:inputType="text"
        android:padding="12dp"
        android:background="#F0F0F0"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:imeOptions="actionSearch"
        android:singleLine="true" />

    <!-- Loading indicator, ditampilkan saat data sedang disiapkan pertama kali -->
    <ProgressBar
        android:id="@+id/progress_loading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- Pesan saat hasil kosong -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kata tidak ditemukan"
        android:textAlignment="center"
        android:textColor="#9E9E9E"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- List hasil pencarian -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_kamus"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

</LinearLayout>